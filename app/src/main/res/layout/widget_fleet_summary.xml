<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FiloTakip"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Günlük Gelir:"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_daily_income"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₺0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#4CAF50" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Günlük Gider:"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_daily_expense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₺0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#F44336" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Net Kar:"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_daily_profit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₺0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1976D2" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Aktif Araçlar:"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_active_vehicles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
